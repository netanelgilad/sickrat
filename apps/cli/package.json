{
	"name": "@sickrat/cli",
	"version": "0.1.22",
	"private": true,
	"type": "module",
	"bin": {
		"sickrat": "./dist/sickrat"
	},
	"scripts": {
		"build": "bun build --compile --outfile dist/sickrat src/index.ts",
		"link:local": "mkdir -p ~/.local/bin && ln -sf \"$PWD/dist/sickrat\" ~/.local/bin/sickrat",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@sickrat/protocol": "0.0.0",
		"qrcode": "^1.5.4"
	},
	"devDependencies": {
		"@types/node": "^25.9.2",
		"@types/qrcode": "^1.5.6",
		"typescript": "^5.5.2"
	}
}
