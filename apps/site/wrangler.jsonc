{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "sickrat-site",
	"compatibility_date": "2026-06-09",
	"assets": {
		"directory": "./dist/client"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "1c7b831c7ca14bf2a6190e5c3e8bf65a"
		}
	],
	"routes": [
		{
			"pattern": "sickrat.dev",
			"custom_domain": true
		},
		{
			"pattern": "www.sickrat.dev",
			"custom_domain": true
		}
	]
}
